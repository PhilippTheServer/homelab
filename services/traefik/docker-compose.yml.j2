---
services:

  traefik:
    image: traefik:{{ traefik_version }}
    container_name: traefik
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    command:
      # API / Dashboard
      - --api.dashboard=true
      # Docker provider — only expose containers with traefik.enable=true
      - --providers.docker=true
      - --providers.docker.exposedbydefault=false
      - --providers.docker.network=proxy
      # Entrypoints
      - --entrypoints.web.address=:80
      - --entrypoints.web.http.redirections.entrypoint.to=websecure
      - --entrypoints.web.http.redirections.entrypoint.scheme=https
      - --entrypoints.websecure.address=:443
      # Let's Encrypt via Cloudflare DNS challenge
      - --certificatesresolvers.letsencrypt.acme.email={{ traefik_acme_email }}
      - --certificatesresolvers.letsencrypt.acme.storage=/letsencrypt/acme.json
      - --certificatesresolvers.letsencrypt.acme.dnschallenge=true
      - --certificatesresolvers.letsencrypt.acme.dnschallenge.provider=cloudflare
      - --certificatesresolvers.letsencrypt.acme.dnschallenge.resolvers=1.1.1.1:53,8.8.8.8:53
{% if letsencrypt_staging %}
      - --certificatesresolvers.letsencrypt.acme.caserver=https://acme-staging-v02.api.letsencrypt.org/directory
{% endif %}
      - --log.level=INFO
      - --accesslog=true
    environment:
      CF_DNS_API_TOKEN: "{{ vault_cloudflare_api_token }}"
    dns:
      - 1.1.1.1
      - 8.8.8.8
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - traefik_letsencrypt:/letsencrypt
    networks:
      - proxy
    labels:
      - "traefik.enable=true"
      # Request wildcard cert for *.home.<domain> — all internal services share it
      - "traefik.http.routers.traefik-dashboard.rule=Host(`traefik.{{ internal_subdomain }}.{{ domain }}`)"
      - "traefik.http.routers.traefik-dashboard.entrypoints=websecure"
      - "traefik.http.routers.traefik-dashboard.tls.certresolver=letsencrypt"
      - "traefik.http.routers.traefik-dashboard.tls.domains[0].main={{ internal_subdomain }}.{{ domain }}"
      - "traefik.http.routers.traefik-dashboard.tls.domains[0].sans=*.{{ internal_subdomain }}.{{ domain }}"
      - "traefik.http.routers.traefik-dashboard.service=api@internal"
      - "traefik.http.routers.traefik-dashboard.middlewares=traefik-auth@docker"
      - "traefik.http.middlewares.traefik-auth.basicauth.users={{ vault_traefik_dashboard_auth | replace('$', '$$') }}"
      - "traefik.http.services.traefik-dashboard.loadbalancer.server.port=8080"

  cloudflared:
    image: cloudflare/cloudflared:latest
    container_name: cloudflared
    restart: unless-stopped
    command: tunnel --no-autoupdate --config /etc/cloudflared/config.yaml run
    environment:
      TUNNEL_TOKEN: "{{ vault_cloudflare_tunnel_token }}"
    volumes:
      - {{ homelab_base_dir }}/services/traefik/cloudflared-config.yaml:/etc/cloudflared/config.yaml:ro
    networks:
      - proxy

networks:
  proxy:
    external: true

volumes:
  traefik_letsencrypt:
    name: traefik_letsencrypt
