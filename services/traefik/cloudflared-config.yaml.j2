# cloudflared origin request defaults
# Applied to all dashboard-managed routes as global defaults.
#
# IMPORTANT — Cloudflare zone prerequisite (one-time dashboard step):
#   philippthesurfer.com → Network → WebSockets → On
#   Required for Headscale's TS2021/Noise protocol (WebSocket upgrade).
originRequest:
  # Keep long-lived WebSocket connections alive (Tailscale coordination stream).
  keepAliveTimeout: 90s
  keepAliveConnections: 10
  # Allow enough time for OIDC redirects and slow clients.
  connectTimeout: 30s
