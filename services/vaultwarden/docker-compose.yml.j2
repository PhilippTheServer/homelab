---
services:

  vaultwarden:
    image: vaultwarden/server:{{ vaultwarden_version }}
    container_name: vaultwarden
    restart: unless-stopped
    environment:
      DATABASE_URL: "postgresql://vaultwarden:{{ vault_vaultwarden_db_password }}@vaultwarden-db/vaultwarden"
      ADMIN_TOKEN: "{{ vault_vaultwarden_admin_token }}"
      DOMAIN: "https://bw.{{ internal_subdomain }}.{{ domain }}"
      SIGNUPS_ALLOWED: "false"
      INVITATIONS_ALLOWED: "true"
      WEBSOCKET_ENABLED: "true"
      # OIDC SSO via Keycloak
      SSO_ENABLED: "true"
      SSO_AUTHORITY: "https://auth.{{ internal_subdomain }}.{{ domain }}/realms/homelab"
      SSO_CLIENT_ID: "vaultwarden"
      SSO_CLIENT_SECRET: "{{ vault_vaultwarden_oidc_secret }}"
    volumes:
      - vaultwarden_data:/data
    depends_on:
      vaultwarden-db:
        condition: service_healthy
    networks:
      - proxy
      - internal
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.vaultwarden.rule=Host(`bw.{{ internal_subdomain }}.{{ domain }}`)"
      - "traefik.http.routers.vaultwarden.entrypoints=websecure"
      - "traefik.http.routers.vaultwarden.tls.certresolver=letsencrypt"
      - "traefik.http.services.vaultwarden.loadbalancer.server.port=80"
      - "traefik.docker.network=proxy"
      # WebSocket router for live vault sync
      - "traefik.http.routers.vaultwarden-ws.rule=Host(`bw.{{ internal_subdomain }}.{{ domain }}`) && Path(`/notifications/hub`)"
      - "traefik.http.routers.vaultwarden-ws.entrypoints=websecure"
      - "traefik.http.routers.vaultwarden-ws.tls.certresolver=letsencrypt"
      - "traefik.http.services.vaultwarden-ws.loadbalancer.server.port=3012"
      - "traefik.docker.network=proxy"

  vaultwarden-db:
    image: postgres:{{ postgres_version }}
    container_name: vaultwarden-db
    restart: unless-stopped
    environment:
      POSTGRES_DB: vaultwarden
      POSTGRES_USER: vaultwarden
      POSTGRES_PASSWORD: "{{ vault_vaultwarden_db_password }}"
    volumes:
      - vaultwarden_db:/var/lib/postgresql
    networks:
      - internal
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U vaultwarden -d vaultwarden"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s

networks:
  proxy:
    external: true
  internal:
    name: vaultwarden_internal
    internal: true

volumes:
  vaultwarden_data:
    name: vaultwarden_data
  vaultwarden_db:
    name: vaultwarden_db
