# Harbor configuration — rendered by Ansible
# Traefik handles TLS; Harbor's internal proxy runs on HTTP only

hostname: registry.{{ internal_subdomain }}.{{ domain }}

http:
  port: 8080

# Disable Harbor's own HTTPS — Traefik terminates TLS
https:
  port: 8443
  certificate: /your/certificate/path   # unused — kept to satisfy schema
  private_key: /your/private/key/path   # unused — kept to satisfy schema

# Harbor internal URL (used for inter-component communication)
internal_tls:
  enabled: false

harbor_admin_password: "{{ vault_harbor_admin_password }}"

database:
  password: "{{ vault_harbor_db_password }}"
  max_idle_conns: 50
  max_open_conns: 100
  conn_max_lifetime: 300
  conn_max_idle_time: 0

data_volume: /data

trivy:
  ignore_unfixed: false
  skip_update: false
  offline_scan: false
  security_check: vuln
  insecure: false
  timeout: 5m

jobservice:
  max_job_workers: 5
  job_loggers:
    - STD_OUTPUT
    - FILE

notification:
  webhook_job_max_retry: 3
  webhook_job_http_client_timeout: 3

log:
  level: info
  local:
    rotate_count: 50
    rotate_size: 200m
    location: /var/log/harbor

_version: "2.0"

# OIDC via Keycloak — configure in Harbor UI after first boot:
# Admin → Configuration → Authentication → OIDC
# Provider URL: https://auth.{{ domain }}/realms/homelab
# Client ID: harbor
# Client Secret: (from Keycloak)
# Scope: openid,profile,email
