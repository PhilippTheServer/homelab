hostname: harbor.{{ internal_subdomain }}.{{ domain }}

http:
  port: 18080

# TLS terminated by Traefik — no https block here
external_url: https://harbor.{{ internal_subdomain }}.{{ domain }}

harbor_admin_password: {{ vault_harbor_admin_password }}

database:
  password: {{ vault_harbor_db_password }}
  max_idle_conns: 100
  max_open_conns: 900
  conn_max_lifetime: 5m
  conn_max_idle_time: 0

data_volume: {{ homelab_base_dir }}/harbor/data

jobservice:
  max_job_workers: 10
  max_job_duration_hours: 24
  job_loggers:
    - STD_OUTPUT
    - FILE
  logger_sweeper_duration: 1

notification:
  webhook_job_max_retry: 3
  webhook_job_http_client_timeout: 3

log:
  level: info
  local:
    rotate_count: 50
    rotate_size: 200M
    location: {{ homelab_base_dir }}/harbor/log

upload_purging:
  enabled: true
  age: 168h
  interval: 24h
  dryrun: false

cache:
  enabled: false
  expire_hours: 24

_version: 2.14.0
